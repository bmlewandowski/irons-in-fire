# Persistence adapter selection
# Accepted values: "local" (LocalStorageAdapter) or "api" (ApiAdapter)
# The application will refuse to start if this variable is absent or unrecognized.
VITE_PERSISTENCE_ADAPTER=local

# Base URL for the REST/GraphQL API (required when VITE_PERSISTENCE_ADAPTER=api)
# Example: https://api.example.com/v1
VITE_API_URL=
